			'''
		DisplayName: Fearmonger Enchantment
	}

	GodSlayerEnchantment: {
		Tooltip:
			'''
			Grants absolute immunity to the 'Godslayer Inferno' debuff
			Any dashes performed ignite nearby enemies with Godslayer Inferno
			Wearing a full Godslayer armor set grants:
			-> +15 defense
			-> +10% damage
			-> +10% movement speed
			'''
		DisplayName: God Slayer Enchantment
	}

	MolluskEnchantment: {
		Tooltip:
			'''
			While you stand still, your stats change every second:
			-> Defense increases by +3 per second (up to +30)
			-> Damage decreases by -5% per second (up to -50%)
			Any movement instantly resets the accumulated bonus
			Staying in water increases defense by 10, but reduces speed by 10%
			'''
		DisplayName: Mollusk Enchantment
	}

	FathomSwarmerEnchantment: {
		DisplayName: Fathom Swarmer Enchantment
		Tooltip:
			'''
			You are constantly aglow with the 'Wet' effect and emit a soft blue light.
			Significantly improves underwater visibility.
			While in water, the following bonuses are activated:
			-> +1 to maximum number of minions.
			-> +3 to maximum number of guards (turrets).
			-> +10% health regeneration.
			-> Reduces damage resistance by 10%.
			'''
	}

	PlaguebringerEnchantment: {
		DisplayName: Plaguebringer Enchantment
		Tooltip:
			'''
			Your summoned minions inflict Plague on enemies for 10 seconds
			When you take damage, you release 5 to 10 Plague Bees
			When your health drops below 100, a powerful Plague explosion occurs around you
			dealing 300 damage to the summoner (30-second cooldown)
			'''
	}

	PlagueReaperEnchantment: {
		Tooltip:
			'''
			Cursed Fire deals damage twice as fast, and Ichor reduces enemy defenses by half.
			Ranged attacks inflict Plague for 10 seconds.
			Flamethrowers additionally poison targets with Acidic Poison for 5 seconds
			If your health drops below 20%, a powerful Plague explosion occurs.
			for 200 ranged damage (30-second cooldown).
			'''
		DisplayName: Plague Reaper Enchantment
	}

	LunicCorpsEnchantment: {
		DisplayName: Lunic Corps Enchantment
		Tooltip:
			'''
			Creates a visible energy shield that has a 5% chance to reflect enemy projectiles.
			Bullet attacks have a 15% chance to cause a shooting star to fall on the enemy (100 damage).
			The chance to save ammo increases the lower your ammo count.
			'''
	}

	TarragonEnchantment: {
		DisplayName: Tarragon Enchantment
