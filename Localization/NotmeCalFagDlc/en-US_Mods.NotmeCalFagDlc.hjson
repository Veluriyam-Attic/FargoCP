		Tooltip:
			'''
			True Melee gains armor penetration equal to 20% of your defense.
			Increases the maximum number of tentacles in the Omega Blue armor set by 5.
			'''
		DisplayName: Omega Blue Enchantment
	}

	FearmongerEnchantment: {
		Tooltip:
			'''
			Grants the effects of the Ego-Crushing trinket
