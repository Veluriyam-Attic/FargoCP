Items: {
	EmpyreanEnchantment: {
		Tooltip:
			'''
			The Rogue's attacks leave a trail of fine Meld plasma particles behind them.
			         Hits inflict the 'Shadow Entropy' debuff for 5 seconds.
			         Shadow Entropy deals massive damage over time, but increases the target's damage by 25%.
			         The Rogue's Stealth builds 20% faster.
			'''
		DisplayName: Empyrean Enchantment
	}

	StyxEnchantment: {
		Tooltip:
			'''
			Every 3 seconds, fires 8 Death Scythes in all directions, dealing 700 damage.
			         If you are wearing a full set of Styx Armor, grants +15 Defense and +10% Movement Speed.  
			'''
		DisplayName: Styx enchantment
	}

	NekomiEnchantment: {
		Tooltip:
			'''
			If you have at least one minion, you gain health regeneration.
			         Regeneration increases by 0.1 health per second for each minion summoned.  
			'''
		DisplayName: Enchantment Nekomi
	}

	MutantEnchantment: {
		Tooltip:
			'''
			Increases damage resistance by 20% (+35% with the full Eternity/Mutant set)
			         Grants immunity to the 'Mutant Bite' debuff
			         Upon detecting nearby enemies, summons 10 homing Phantasmatic Eyes (1000 damage)
			         Set Synergy: Your projectiles explode with a Phantasmatic Blast on impact
			'''
		DisplayName: Mutant Enchantment
	}

	GaiaEnchantment: {
		Tooltip:
			'''
			Melee attacks grant a Bug Armor attack speed buff for 10 seconds
			         Ranged attacks increase critical damage by 15% for 10 seconds
			         Magic attacks heal you for 2 health
			         Whip attack speed increased by 10%
			'''
		DisplayName: Gaia Enchantment
	}

	EridanusEnchantment: {
		Tooltip:
			'''
			Increases damage and attack speed for all classes by 15%
			         Press the mod's custom key to activate ZA WARUDO!
			         Freezes time around you for 10 seconds (1-minute cooldown)
			'''
		DisplayName: Eridanus Enchantment
	}

	MutantArtifact: {
		Tooltip:
			'''
			Combines the great power of five enchantments:
			         • Grants health regeneration from your minions (Nekomi)
			         • Grants class buffs on attacks and increases whip speed by 10% (Gaia)
			         • Allows you to stop time with the [ZA WARUDO!] key (Eridanus)
			         • Releases death scythes every 3 seconds and buffs Styx's armor (Styx)
			         • Grants +20% defense, spawns eyes, and detonates projectiles in the Eternity set (Mutant)
			'''
		DisplayName: Force of the mutant
	}

	FargosSoul: {
		Tooltip:
			'''
			True Fusion of Eternity.
			         Combines absolutely all the effects of Cupid's Cursed Heart and Mutant Artifact
			         Passively grants the true set bonuses of five armor sets (even when not equipped):
			         • Activates the accumulation and ultimate of Reaper's Scythe charges (Stix Bonus)
			         • Summons the Visage of Abomination, a ring of spheres, and Death Lasers (Eternity Bonus)
			         • Transforms all your attacks into super mode with the God Eater debuff
			         • Applies all passive effects of the Nekomi, Gaia, and Eridanus sets
			'''
		DisplayName: Fargo's Soul
	}

	CursedHeartOfCupid: {
		Tooltip:
			'''
			Combines the effects of Sparkling Adoration, Vile Wand, and Mutant Eye:
			         • Grants immunity to Love, False Hearts, Vile Fang/Presence, and Mutant Bite
			         • Activates a Graze aura: Dodging projectiles increases damage (limit increased by 25%)
			         • Your attacks periodically create life-sucking beams of love
			         • Spectral Abomination periodically sustains your critical hits
			         • Allows you to survive any fatal blow with 1 HP (recovers at full health)
			         • Press the Mutant Bomb button to destroy projectiles with a wave of spheres (60-second cooldown)
			         • Styx's armor stores energy at maximum Graze
			'''
		DisplayName: Cursed Heart Of Cupid
	}

	WaffleBoots: {
