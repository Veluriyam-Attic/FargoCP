			'''
		DisplayName: 利维坦牙齿项链
	}

	AstralVertebrae: {
		DisplayName: 星幻脊骨
		Tooltip:
			'''
			使你免疫[cbuff:CalamityMod/AstralInfectionDebuff]减益，增加5%跳跃高度
