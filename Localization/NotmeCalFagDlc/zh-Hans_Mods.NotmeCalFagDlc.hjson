			[c/00ff87:永恒]
			'''
	}

	LeviathanToothNecklace: {
		Tooltip:
			'''
			召唤阿娜希塔的音符环绕你并攻击敌怪
			静止5秒后获得完全隐身，再次移动解除隐身
