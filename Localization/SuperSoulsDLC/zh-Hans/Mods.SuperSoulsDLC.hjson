Items: {
	CursedEnchant: {
		DisplayName: 诅咒魔石
		Tooltip:
			'''
			[i:SOTS/CursedHood] 召唤一块红玉石碑在你身边
			[i:SOTS/CursedHood] 离最近的敌人将受到诅咒
			   -被诅咒的敌人受到伤害时会被爆闪，并受到140%额外伤害，且会对附近敌人造成140%伤害
			   -此效果有2秒冷却时间
			[i:SOTS/CursedApple] 获得诅咒苹果的效果
			[i:SOTS/HeartInAJar] 获得罐中之心的效果
			[i:SOTS/PricklyPearShield] 获得刺梨盾的效果
			[i:SOTS/RotHeart] 获得腐烂之心的效果
			'''
	}

	DrillforgeEnchant: {
		DisplayName: 钻炉魔石
		Tooltip:
			'''
			[i:SOTS/ExcavatorHelmet] 获得一条导弹发射器尾部，会消耗1点虚空值攻击附近敌人
			[i:SOTS/ExperimentalInjection] 获得所有实验注射器的效果：
			   -首次攻击会施加永久的出血，每秒造成5点伤害，并增加20点最大生命值
			   -首次攻击会必定暴击，并增加20%暴击伤害
			   -首次攻击会造成中毒debuff，并吸取生命值
			   -增加5%伤害，攻击速度，移动速度
			[i:SOTS/TinyPlanetoid] 获得微型小行星的效果
			'''
	}

	EarthenEnchant: {
		DisplayName: 陆地魔石
		Tooltip:
			'''
			[i:SOTS/EarthenHelmet] 近战攻击有概率对敌人施加一种可叠加的永久损伤，使敌人在所有攻击中受到额外的伤害
			[i:SOTS/EarthenHelmet] 穿戴时会增强视线并提供光照
			[i:SOTS/EarthenHelmet] 增加10%挖矿速度和移动速度
			[i:SOTS/RockCandy] 获得岩石冰糖的效果
			[i:SOTS/AutoClicker] 获得连点手套的效果
			'''
	}

	ElementalEnchant: {
		DisplayName: 元素魔石
		Tooltip:
			'''
			[i:SOTS/ElementalHelmet] 按下'{0}'键传送至鼠标处，对你路径上的所有敌人造成你防御值的200%点伤害
			[i:SOTS/ElementalHelmet] 增加100点最大虚空值
			[i:SOTS/ElementalHelmet] 增加3点虚空恢复量
			[i:SOTS/FocusReticle] 获得聚焦十字镜的效果
			[i:SOTS/AcidicInjection] 获得残杀注射器的效果
			[i:SOTS/MidnightPrism] 获得午夜棱镜的效果
			'''
	}

	FrigidEnchant: {
		DisplayName: 极寒魔石
		Tooltip:
			'''
			[i:SOTS/FrigidCrown] 获得溜冰鞋的效果
			[i:SOTS/FrigidRobe] 极寒标枪获得额外3次弹跳机会
			[i:SOTS/FrigidRobe] 极寒标枪不再消耗虚空值
			[i:SOTS/ShatterShardChestplate] 受伤时会生成1-3块冰碎块围绕你
			[i:SOTS/ShatterShardChestplate] 免疫冷冻，冰冻和霜冻debuff
			[i:SOTS/ShoeIce] 获得冰鞋的效果
			'''
	}

	FrostArtifactEnchant: {
		DisplayName: 霜遗魔石
		Tooltip:
			'''
			[i:SOTS/FrostArtifactHelmet] 大多数近战和远程攻击都会召唤少量极地炮，每个极地炮造成25%伤害
			[i:SuperSoulsDLC/FrigidEnchant] 获得极寒魔石的效果
			[i:SOTS/FrigidHourglass] 获得极寒沙漏的效果
			[i:SOTS/ShardGuard] 获得冰碎块护盾的效果
