Items: {
	CursedEnchant: {
		DisplayName: 诅咒魔石
		Tooltip:
			'''
			离最近的敌人将受到诅咒
			被诅咒的敌人受到伤害时会被爆闪，并受到140%额外伤害，且会对附近敌人造成140%伤害
			此效果有2秒冷却时间
			'''
	}

	DrillforgeEnchant: {
		DisplayName: 钻炉魔石
		Tooltip: 获得一条导弹发射器尾部，会消耗1点虚空值攻击附近敌人
	}

	EarthenEnchant: {
		DisplayName: 陆地魔石
		Tooltip: 近战攻击有概率对敌人施加一种可叠加的永久损伤，使敌人在所有攻击中受到额外的伤害
	}

	ElementalEnchant: {
		DisplayName: 元素魔石
		Tooltip: 允许你传送至你的光标位置
	}

	FrigidEnchant: {
		DisplayName: 极寒魔石
		Tooltip:
			'''
			受伤时会生成1-3块冰碎块围绕你
			免疫冷冻，冰冻和霜冻减益
			'''
	}

	FrostArtifactEnchant: {
		DisplayName: 霜遗魔石
		Tooltip:
			'''
			攻击会召唤大量极地炮，每个极地炮造成25%伤害
			[i:SuperSoulsDLC/FrigidEnchant] 获得极寒魔石的效果
			'''
	}

	PatchLeatherEnchant: {
		DisplayName: 皮衣魔石
		Tooltip: 召唤3只飞蛇协助战斗
	}

	TwilightAssassinEnchant: {
		DisplayName: 昏影魔石
		Tooltip:
			'''
			定期积攒最多5把围绕你旋转的全息剑
			每10次攻击都会向鼠标处发射剑刃，造成近战伤害
			'''
	}

	VesperaEnchant: {
		DisplayName: 薄暮魔石
		Tooltip: 增加50点最大虚空值和1点虚空恢复量
	}

	VibrantEnchant: {
		DisplayName: 振荡魔石
		Tooltip: 虚空武器会额外射出振荡闪电
	}

	VoidspaceRangerEnchant: {
		DisplayName: 虚游魔石
		Tooltip:
			'''
			攻击会永久造成亚空之焰减益，每秒造成10点伤害
			当一个拥有亚空之焰的敌人被杀死时，它们会对其他所有敌人造成伤害，伤害相当于从亚空之焰中累计受到的伤害
			'''
	}

	WormwoodEnchant: {
		DisplayName: 流胶木魔石
		Tooltip: 召唤3个盛花钩协助战斗
	}

	ChaosForce: {
		DisplayName: 混沌之力
		Tooltip:
			'''
			[i:SuperSoulsDLC/CursedEnchant] 离最近的敌人将受到诅咒
			[i:SuperSoulsDLC/DrillforgeEnchant] 获得一条导弹发射器尾部，会消耗1点虚空值攻击附近敌人
			[i:SuperSoulsDLC/PatchLeatherEnchant] 召唤5只飞蛇协助战斗
			[i:SuperSoulsDLC/VesperaEnchant] 增加100点最大虚空值和2点虚空恢复量
			[i:SuperSoulsDLC/VibrantEnchant] 虚空武器会额外射出振荡闪电
			[i:SuperSoulsDLC/WormwoodEnchant] 召唤5个盛花钩协助战斗
			'''
	}

	TessellationForce: {
		DisplayName: 嵌形之力
		Tooltip:
			'''
			[i:SuperSoulsDLC/EarthenEnchant] 近战攻击有概率对敌人施加一种可叠加的永久损伤，使敌人在所有攻击中受到额外的伤害
			[i:SuperSoulsDLC/ElementalEnchant] 允许你传送至你的光标位置
			[i:SuperSoulsDLC/FrostArtifactEnchant] 攻击会召唤大量极地炮，每个极地炮造成25%伤害
