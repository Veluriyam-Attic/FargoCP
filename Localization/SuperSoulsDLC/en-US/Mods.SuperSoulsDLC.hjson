Items: {
	CursedEnchant: {
		DisplayName: Cursed Enchantment
		Tooltip:
			'''
			The closest enemy to you is afflicted with a curse
			Upon taking damage, cursed enemies will Flare, taking 140% additional damage and dealing 140% damage to other nearby enemies
			This effect has a 2 second cooldown
			'''
	}

	DrillforgeEnchant: {
		DisplayName: Drillforge Enchantment
		Tooltip: Gain a Missile Launcher tail that attacks nearby enemies for 1 void
	}

	EarthenEnchant: {
		DisplayName: Earthen Enchantment
		Tooltip: Attacks have a chance to apply a stacking, permanent shred on enemies, making them take additional damage from all attacks
	}

	ElementalEnchant: {
		DisplayName: Elemental Enchantment
		Tooltip: Allows you to teleport to your cursor
	}

	FrigidEnchant: {
		DisplayName: Frigid Enchantment
		Tooltip:
			'''
			Taking damage spawns 1-3 Shatter Shards
			Grants immunity to Chilled, Frozen, and Frostburn
			'''
	}

	FrostArtifactEnchant: {
		DisplayName: Frost Artifact Enchantment
		Tooltip:
			'''
			Attacks summon a handful of Polar Cannons that each deal 25% damage
			[i:SuperSoulsDLC/FrigidEnchant] Effects of Frigid Enchantment
			'''
	}

	PatchLeatherEnchant: {
		DisplayName: Patch Leather Enchantment
		Tooltip: Summons 3 flying snakes to attack nearby enemies
	}

	TwilightAssassinEnchant: {
		DisplayName: Twilight Assassin Enchantment
		Tooltip:
			'''
			Periodically accumulate up to 5 swords that rotate around you
			Every 10th attack will launch forth the swords, dealing melee damage
			'''
	}

	VesperaEnchant: {
		DisplayName: Vespera Enchantment
		Tooltip: Increases max void by 50 and void gain by 1
	}

	VibrantEnchant: {
		DisplayName: Vibrant Enchantment
		Tooltip: Void weapons will fire out additional vibrant bolts
	}

	VoidspaceRangerEnchant: {
		DisplayName: Voidspace Ranger Enchantment
		Tooltip:
			'''
			Attacks permanently inflict the Subspace Flames debuff, which deals 10 damage per second
			When an enemy with Subspace Flames is killed, they deal damage to all other enemies equal to the cumulative damage they took from Subspace Flames
			'''
	}

	WormwoodEnchant: {
		DisplayName: Wormwood Enchantment
		Tooltip: Summons 3 Blooming Hooks to assist in combat
	}

	ChaosForce: {
		DisplayName: Force of Chaos
		Tooltip:
			'''
			[i:SuperSoulsDLC/CursedEnchant] The closest enemy to you is afflicted with a curse
			[i:SuperSoulsDLC/DrillforgeEnchant] Gain a Missile Launcher tail that attacks nearby enemies for 1 void
			[i:SuperSoulsDLC/PatchLeatherEnchant] Summons 5 flying snakes to attack nearby enemies
			[i:SuperSoulsDLC/VesperaEnchant] Increases max void by 100 and void gain by 2
			[i:SuperSoulsDLC/VibrantEnchant] Void weapons will fire out additional vibrant bolts
			[i:SuperSoulsDLC/WormwoodEnchant] Summons 5 Blooming Hooks to assist in combat
			'''
	}

	TessellationForce: {
		DisplayName: Force of Tessellation
		Tooltip:
			'''
			[i:SuperSoulsDLC/EarthenEnchant] Attacks have a chance to apply a stacking, permanent shred on enemies, making them take additional damage from all attacks
			[i:SuperSoulsDLC/ElementalEnchant] Allows you to teleport to your cursor
			[i:SuperSoulsDLC/FrostArtifactEnchant] Attacks summon a handful of Polar Cannons that each deal 25% damage
			[i:SuperSoulsDLC/TwilightAssassinEnchant] Periodically accumulate up to 9 swords that rotate around you
			[i:SuperSoulsDLC/TwilightAssassinEnchant] Every 10th attack will launch forth the swords, dealing melee damage
			[i:SuperSoulsDLC/VoidspaceRangerEnchant] Attacks permanently inflict the Subspace Flames debuff, which deals 10 damage per second
			'''
	}

	VoidEmblem: {
		DisplayName: Void Emblem
		Tooltip: 15% increased void damage
	}

	VoidlingEssence: {
		DisplayName: Voidling's Essence
		Tooltip:
			'''
			18% increased void damage
			8% increased void crit chance
			Increases max void by 50
			'This is only the beginning...'
			'''
	}

	VoidbearerSoul: {
		DisplayName: Voidbearer's Soul
		Tooltip:
			'''
			22% increased void damage
			10% increased void crit chance
			Increases max void by 100
			Effects of Synthetic Liver and Voidmage Incubator
			Effects of Mr. Eepy, Mr. Glorp, and Mr. McMillen
			'The call of the void grows ever louder...'
			'''
	}

	FungusEnchant: {
		Tooltip:
			'''
			Sentries summon mushroom spores around them
			Summoning radius scales with sentry damage
			'''
		DisplayName: Fungus Enchantment
	}

	AuroraEnchant: {
		Tooltip: Summons 2 aurora Slimes to rotate around you, dealing summon damage
		DisplayName: Aurora Enchantment
	}

	BiologicEnchant: {
		DisplayName: Biologic Enchantment
		Tooltip: Grants the ability to summon a gas station to buff yourself
	}

	ChronoEnchant: {
		DisplayName: Chrono Enchantment
		Tooltip: Grants the ability to delay death by 10 seconds when taking a fatal blow
	}

	EquilibriumEnchant: {
		DisplayName: Equilibrium Enchantment
		Tooltip: Releases regenerating fog over time
	}

	FiveStarGeneralEnchant: {
		DisplayName: Five-Star General Enchantment
		Tooltip: Increases minion slots by 77%, but reduces base damage of minions by 38%
	}

	FlinxFurEnchant: {
		DisplayName: Flinx Fur Enchantment
		Tooltip:
			'''
			Minions leave behind patches of flinx fur on the ground
			Flinx fur patches stick to enemies and reduce their horizontal movement speed by 25%
			'''
	}

	ForestEnchant: {
		DisplayName: Forest Enchantment
		Tooltip: Thorns grow from hit enemies, dealing ranged damage
	}

	IndividualCombatEnchant: {
		DisplayName: Individual Combat Enchantment
		Tooltip: The farther away from enemies you are the more damage you do
	}

	OnyxEnchant: {
		DisplayName: Onyx Enchantment
		Tooltip:
			'''
			Strike enemies to summon an onyx above them
			Killing the onyx will drop shards onto the targeted enemy
			'''
	}

	ReflectorEnchant: {
		DisplayName: Reflector Enchantment
		Tooltip: Generates a shield that can reflect most hostile projectiles
	}

	SunGodEnchant: {
		DisplayName: Sun God Enchantment
		Tooltip:
			'''
			The explosion deals 500 melee damage plus 2x your held weapon's damage
			Inflicts Solar Burnt for 2 minutes
			5 minute cooldown
			'''
	}

	WatchmanEnchant: {
		DisplayName: Watchman Enchantment
		Tooltip:
			'''
			Grants you and your team the acceleration buff upon hitting an enemy
			Acceleration grants:
			+15 life and mana regeneration
			25% increased movement speed
			50% increased movement acceleration
			20% increased melee speed
			10% increased attack speed
			'''
	}

	BalanceForce: {
		DisplayName: Force of Balance
		Tooltip:
			'''
			[i:SuperSoulsDLC/BiologicEnchant] Grants the ability to summon a gas station to buff yourself
			[i:SuperSoulsDLC/ChronoEnchant] Grants the ability to delay death by 10 seconds when taking a fatal blow
			[i:SuperSoulsDLC/EquilibriumEnchant] Releases regenerating fog over time
			[i:SuperSoulsDLC/FiveStarGeneralEnchant] Increases minion slots by 77%, but reduces base damage of minions by 38%
