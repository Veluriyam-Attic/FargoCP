	}

	ConclusionForce: {
		DisplayName: Force of Conclusion
		Tooltip:
			'''
			[i:SuperSoulsDLC/AuroraEnchant] Summons 4 aurora Slimes to rotate around you, dealing summon damage
			[i:SuperSoulsDLC/ForestEnchant] Thorns grow from hit enemies and when you are hit, dealing ranged damage
			[i:SuperSoulsDLC/ReflectorEnchant] Generates a damaging shield that can reflect most hostile projectiles
			[i:SuperSoulsDLC/WatchmanEnchant] Grants you and your team the acceleration buff upon hitting an enemy
			'''
	}

	HighlandForce: {
		DisplayName: Force of Highland
		Tooltip:
			'''
			[i:SuperSoulsDLC/FungusEnchant] Sentries summon mushroom spores around them
			[i:SuperSoulsDLC/FlinxFurEnchant] Minions leave behind patches of flinx fur on the ground
			[i:SuperSoulsDLC/IndividualCombatEnchant] The farther away from enemies you are the more damage you do
